@using BlogProject.Entities.Messages
@model List<ErrorMessageObj>
@{
    ViewBag.Title = "Geçersiz İşlem";
}


<link href="~/Content/css/login-register.css" rel="stylesheet" />
<script src="~/Scripts/jquery-3.6.0.min.js"></script>
<div class="wrapper fadeInDown">
    <div id="formContent">
        <!-- Tabs Titles -->
        <!-- Icon -->
        <div class="fadeIn first">
            <h3 class="text-center" style="color:cornflowerblue">YÖNLENDİRİLİYORSUNUZ</h3>
        </div>
        <div class="main-content">
            <div class="text-success">
                <h2><span class="glyphicon glyphicon-remove"></span>&nbsp;&nbsp;&nbsp;&nbsp; Gerçersiz İşlem.</h2>
                <hr />
                <p class="text-justify">
                    @foreach (ErrorMessageObj item in Model)
                    {
                        @item.Message<br />
                    }
                </p>
            </div>
        </div>

        <!-- Remind Passowrd -->
        <div id="formFooter">
            @*<a class="underlineHover" href="#">Forgot Password?</a>*@
        </div>

    </div>
</div>

<script>
    $(function () {
        $("footer").parent().hide();
    });

    setTimeout(function () {
        window.location = "/Home/Index";
    }, 5000);
</script>

